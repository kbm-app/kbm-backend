# Copy to kbm-backend/.env on the VPS, fill in real secrets, never commit it.

APP_NAME=KBM
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.kbmdigital.my.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Container name "kbm_db" from deploy/docker-compose.yml, same default network as kbm_app.
DB_CONNECTION=pgsql
DB_HOST=kbm_db
DB_PORT=5432
DB_DATABASE=kbm
DB_USERNAME=kbm
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leading dot shares the session cookie across kbmdigital.my.id and api.kbmdigital.my.id.
SESSION_DOMAIN=.kbmdigital.my.id

FRONTEND_URL=https://kbmdigital.my.id
SANCTUM_STATEFUL_DOMAINS=kbmdigital.my.id

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=r2
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@kbmdigital.my.id"
MAIL_FROM_NAME="${APP_NAME}"

CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=kbm
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_URL=https://pub-<hash>.r2.dev

# OpenWA runs on its own dedicated VPS, not this one — see kbm-wa/deploy/DEPLOYMENT.md.
# Leave WA_PROVIDER=null until that's deployed and you have a real API key.
WA_PROVIDER=null
WA_BASE_URL=https://wa.kbmdigital.my.id
WA_API_KEY=
WA_SESSION_ID=default

VITE_APP_NAME="${APP_NAME}"
